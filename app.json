{
  "expo": {
    "name": "lingostickers-mobile",
    "slug": "lingostickers-mobile",
    "scheme": "lingostickers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.iancheung228.lingostickers",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "LingoStickers uses your camera to scan objects and create vocabulary stickers.",
        "NSLocationWhenInUseUsageDescription": "LingoStickers can tag where this memory happened, turning your collection into a map of your language journey. This is entirely optional.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "LingoStickers uses your camera to scan objects and create vocabulary stickers."
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "LingoStickers saves your stickers to your photo library so you can share them as chat stickers.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "LingoStickers needs access to your photo library so you can pick a picture to turn into a sticker."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "LingoStickers can tag where this memory happened, turning your collection into a map of your language journey. This is entirely optional."
        }
      ],
      "expo-audio",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#A7D7C5"
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "497514cf-549d-4ce7-a873-4675cab5b9dc"
      }
    },
    "owner": "iancheung228"
  }
}
