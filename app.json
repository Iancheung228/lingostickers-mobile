{
  "expo": {
    "name": "lingostickers-mobile",
    "slug": "lingostickers-mobile",
    "scheme": "lingostickers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "LingoStickers uses your camera to scan objects and create vocabulary stickers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "LingoStickers uses your camera to scan objects and create vocabulary stickers."
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "LingoStickers saves your stickers to your photo library so you can share them as chat stickers."
        }
      ]
    ]
  }
}
